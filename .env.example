# ──────────────────────────────────────────────
# CloudSeven Agent — Environment Variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. `.env.example` is committed.
# ──────────────────────────────────────────────

# Which LLM provider to use: "ollama" | "anthropic" | "openai"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
# Default: qwen2.5:14b — strong tool calling, runs well on 24GB+ RAM.
# For faster iteration on lower-RAM machines, use llama3.2:3b.
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_HOST=http://localhost:11434

# Anthropic settings (used when LLM_PROVIDER=anthropic) — leave blank for Phase 1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Data layer: "json" now, "api" or "postgres" later
DATA_BACKEND=json
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console  # "console" for dev, "json" for production

# App
APP_ENV=development  # development | staging | production
